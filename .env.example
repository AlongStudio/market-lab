# market_lab 数据库(NAS 已有 MySQL 实例)
DB_HOST=192.168.1.99
DB_PORT=3306
DB_NAME=market_lab
DB_USER=root
DB_PASSWORD=

# 服务端口(对外仅映射页面端口,API 端口不映射)
HTTP_PORT=3000
# 静态报告输出目录(容器内,挂载到 NAS 供文件服务读取)
REPORTS_DIR=/reports

# 回填深度:0=从上市日全历史,>0=最近 N 年
BACKFILL_YEARS=0
# akshare 全局 QPS 限流
AKSHARE_QPS=2
# 分钟K 哈希分表数
MINUTE_HASH_TABLES=32

# IP 白名单(本阶段关闭)
IP_WHITELIST_ENABLED=false
IP_WHITELIST=

# 采集健壮性:单次 akshare 外呼超时(秒)/ 单任务整体超时(秒)/ RUNNING 卡死回收阈值(分钟)
AKSHARE_TIMEOUT=30
TASK_TIMEOUT=90
STALE_RUNNING_MINUTES=30
# 回填按 N 年分片生成任务,降低单任务失败成本
BACKFILL_CHUNK_YEARS=3

# 鉴权:JWT 签名密钥(务必改成强随机值,例如 openssl rand -hex 32)
AUTH_SECRET=change-me-in-production-please
# token 有效期(秒),默认 7 天;每次访问滑动续期
TOKEN_TTL=604800
# 启动时自动播种初始登录用户(为空则不播种;留空,用户直接入库管理)
AUTH_INIT_USER=
AUTH_INIT_PASSWORD=
