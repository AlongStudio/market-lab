# market_lab 数据库(NAS 已有 MySQL 实例)
DB_HOST=192.168.1.99
DB_PORT=3306
DB_NAME=market_lab
DB_USER=root
DB_PASSWORD=

# 服务端口(对外仅映射页面端口,API 端口不映射)
HTTP_PORT=3000
# 静态报告输出目录(容器内,挂载到 NAS 供文件服务读取)
REPORTS_DIR=/reports

# 回填深度:0=从上市日全历史,>0=最近 N 年
BACKFILL_YEARS=0
# akshare 全局 QPS 限流
AKSHARE_QPS=2
# 分钟K 哈希分表数
MINUTE_HASH_TABLES=32

# IP 白名单(本阶段关闭)
IP_WHITELIST_ENABLED=false
IP_WHITELIST=
